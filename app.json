{
  "expo": {
    "name": "SIS Checklist",
    "slug": "sis-checklist",
    "version": "1.0.0",

    "orientation": "portrait",

    "icon": "./assets/icon.png",

    "userInterfaceStyle": "light",

    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#001E3D"
    },

    "ios": {
      "supportsTablet": true,

      "config": {
        "googleMapsApiKey": "AIzaSyABKUkrFmKs6xzs7LuoapEvxyXG77kvvNk"
      }
    },

    "android": {
      "package": "com.sisit.checklist",

      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#0A1E40"
      },

      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyABKUkrFmKs6xzs7LuoapEvxyXG77kvvNk"
        }
      }
    },

    "web": {
      "favicon": "./assets/favicon.png"
    },

    "plugins": [

      [
        "expo-image-picker",
        {
          "cameraPermission": "Permita que o SIS Checklist use a camera para anexar fotos aos registros.",

          "photosPermission": "Permita que o SIS Checklist acesse fotos para anexar imagens aos registros.",

          "microphonePermission": false
        }
      ],

      "expo-font"

    ],

    "extra": {
      "eas": {
        "projectId": "07f5eda7-cba0-4a28-aa19-03ceb43c3ffa"
      }
    }
  }
}